.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Database
*.db
*.sqlite
*.sqlite3

# Uploads
uploads/*
!uploads/.gitkeep

# Logs
logs/
*.log

# OS
Thumbs.db
.DS_Store

# Testing
coverage/
.nyc_output/

# Cache
.cache/
.eslintcache

# Temporary files
*.tmp
*.temp
